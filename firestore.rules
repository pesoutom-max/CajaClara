rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isMaster() {
      return isSignedIn()
        && myUserDoc().data.role == "master"
        && myUserDoc().data.isActive == true;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isMaster();
      allow list: if isMaster();
      allow create: if isOwner(userId) || isMaster();
      allow update: if isOwner(userId) || isMaster();
      allow delete: if isMaster();
    }

    match /users/{userId}/sales/{saleId} {
      allow get, list, create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    match /users/{userId}/expenses/{expenseId} {
      allow get, list, create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    match /users/{userId}/quickProducts/{quickProductId} {
      allow get, list, create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    match /users/{userId}/dailySummaries/{dailySummaryId} {
      allow get, list, create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    // New rule for Daily Closes
    match /users/{userId}/daily_closes/{dailyCloseId} {
      allow get, list, create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }
  }
}
